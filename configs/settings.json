    "npm:@estebanforge/pi-agentmemory",
    "npm:@mcowger/pi-better-messages-cache",
    "npm:glm-vision",
    "npm:pi-token-speed",
    "npm:pi-diff-review",
    "npm:@juicesharp/rpiv-ask-user-question",
